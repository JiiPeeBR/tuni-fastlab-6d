VAR CONSTANT
	gMAX_SHUTTLE_COUNT : UINT := 35; (*Maximum numer of shuttles on the system*)
	gMAX_INDEX_SHUTTLE : UINT := gMAX_SHUTTLE_COUNT-1; (*Maximum index for a shuttles on the system*)
END_VAR
