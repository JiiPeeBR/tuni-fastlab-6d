VAR
	gCommInput : Mc6DControllerFBIOType; (*Communication variable INPUT*)
	gCommOutput : Mc6DControllerFBIOType; (*Communication variable OUTPUT*)
END_VAR
(**)
(*Shuttles*)
VAR
	gShuttles : ShuttleListType;
END_VAR
(**)
